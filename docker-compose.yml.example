# ORTHANC-AUTHELIA STANDALONE - Complete medical imaging solution
# Uses external PostgreSQL database container (or optional local PostgreSQL)
# Includes Redis, Orthanc, OHIF, Authelia, and Nginx
#
# =============================================================================
# SETUP INSTRUCTIONS
# =============================================================================
#
# 1. Copy this file to docker-compose.yml:
#    cp docker-compose.yml.example docker-compose.yml
#
# 2. Copy and configure example files from the root directory:
#    cp .env.example .env
#    cp authelia-configuration.yml.example services/authelia/config/configuration.yml
#    cp authelia-users.yml.example services/authelia/config/users_database.yml
#    cp orthanc.json.example services/orthanc/config/orthanc.json
#
# 3. Edit the configuration files with your credentials:
#    - .env: Update all secrets and passwords
#    - services/authelia/config/configuration.yml: Update domain and secrets
#    - services/authelia/config/users_database.yml: Generate user passwords
#    - services/orthanc/config/orthanc.json: Update PostgreSQL credentials
#
# 4. See README.md for detailed setup instructions
#
# =============================================================================

services:
  # =============================================================================
  # DATABASE SERVICES
  # =============================================================================

  redis:
    image: redis:8.0-alpine
    container_name: orthanc-redis
    restart: unless-stopped
    healthcheck:
      test: ["CMD", "redis-cli", "ping"]
      interval: 10s
      timeout: 5s
      retries: 5
      start_period: 30s
    networks:
      - orthanc-network

  # ---------------------------------------------------------------------------
  # OPTIONAL: Local PostgreSQL (uncomment to use instead of external database)
  # ---------------------------------------------------------------------------
  # If using local PostgreSQL:
  # 1. Uncomment the postgres service below
  # 2. Uncomment the postgres_data volume in the volumes section
  # 3. Remove the "database" network from orthanc service
  # 4. Remove the external "database" network definition at the bottom
  # 5. Update orthanc depends_on to include postgres
  # 6. Change POSTGRES_HOST to "postgres" in orthanc environment
  # ---------------------------------------------------------------------------

  # postgres:
  #   image: postgres:16-alpine
  #   container_name: orthanc-postgres
  #   restart: unless-stopped
  #   environment:
  #     - POSTGRES_DB=orthanc
  #     - POSTGRES_USER=orthanc
  #     - POSTGRES_PASSWORD=change_this_password
  #   volumes:
  #     - postgres_data:/var/lib/postgresql/data
  #   networks:
  #     - orthanc-network

  # =============================================================================
  # AUTHENTICATION SERVICES
  # =============================================================================
  
  auth-service:
    image: registry.yokoinc.ovh/orthanc-auth-service:1.0.8
    container_name: orthanc-auth-service
    restart: unless-stopped
    environment:
      # Essential Configuration (from .env)
      - LANGUAGE=${LANGUAGE}
      - AUTH_USERNAME=${AUTH_USERNAME}
      - AUTH_PASSWORD=${AUTH_PASSWORD}
      - REDIS_HOST=redis
      # Optional overrides (uncomment in .env if needed)
      - LOG_LEVEL=${LOG_LEVEL:-INFO}
      - DEFAULT_TOKEN_MAX_USES=${DEFAULT_TOKEN_MAX_USES:-50}
      - DEFAULT_TOKEN_VALIDITY_SECONDS=${DEFAULT_TOKEN_VALIDITY_SECONDS:-604800}
      - CACHE_VALIDITY_USER_SESSION=${CACHE_VALIDITY_USER_SESSION:-300}
      - CACHE_VALIDITY_SHARE_TOKEN=${CACHE_VALIDITY_SHARE_TOKEN:-60}
      - AUDIT_RETENTION_DAYS=${AUDIT_RETENTION_DAYS:-90}
      - JS_REFRESH_INTERVAL=${JS_REFRESH_INTERVAL:-30000}
      - JS_DEBUG_MODE=${JS_DEBUG_MODE:-false}
    depends_on:
      redis:
        condition: service_healthy
    networks:
      - orthanc-network

  authelia:
    image: authelia/authelia:4.39.5
    container_name: orthanc-authelia
    restart: unless-stopped
    depends_on:
      redis:
        condition: service_healthy
    volumes:
      - ./services/authelia/config:/config
    networks:
      - orthanc-network
    environment:
      - TZ=${TZ}
      - AUTHELIA_SESSION_SECRET=${AUTHELIA_SESSION_SECRET}
      - AUTHELIA_STORAGE_ENCRYPTION_KEY=${AUTHELIA_STORAGE_ENCRYPTION_KEY}
      - AUTHELIA_IDENTITY_VALIDATION_RESET_PASSWORD_JWT_SECRET=${AUTHELIA_JWT_SECRET}
      - AUTHELIA_LOG_LEVEL=${AUTHELIA_LOG_LEVEL:-info}
      - REDIS_HOST=redis
      - REDIS_PORT=6379
      - REDIS_DB=0

  # =============================================================================
  # PACS CORE SERVICES
  # =============================================================================
  
  orthanc:
    image: jodogne/orthanc-plugins:latest
    container_name: orthanc-server
    restart: unless-stopped
    depends_on:
      auth-service:
        condition: service_started
      # postgres:  # Uncomment if using local PostgreSQL
      #   condition: service_started
    volumes:
      - ./services/orthanc/config/orthanc.json:/etc/orthanc/orthanc.json:ro
    networks:
      - orthanc-network
      - database  # Remove this line if using local PostgreSQL
    environment:
      - POSTGRES_HOST=database  # Change to "postgres" if using local PostgreSQL
      - POSTGRES_PORT=5432
      - POSTGRES_DB=orthanc
      - POSTGRES_USER=orthanc
      - POSTGRES_PASSWORD=change_this_password

  # =============================================================================
  # MEDICAL IMAGING VIEWERS
  # =============================================================================
  
  ohif:
    image: registry.yokoinc.ovh/orthanc-ohif:3.11.0
    container_name: orthanc-ohif
    restart: unless-stopped
    volumes:
      - ./services/ohif/config/app-config.js:/usr/share/nginx/html/ohif/app-config.js:ro
    depends_on:
      - orthanc
    networks:
      - orthanc-network

  # =============================================================================
  # REVERSE PROXY & LOAD BALANCER
  # =============================================================================
  
  nginx:
    image: registry.yokoinc.ovh/orthanc-nginx:1.0.3
    container_name: orthanc-nginx
    restart: unless-stopped
    ports:
      - "30080:80"
      - "30443:443"
    volumes:
      - nginx-ssl:/etc/nginx/ssl
    environment:
      - DOMAIN=${DOMAIN}
      - SSL_MODE=${SSL_MODE:-selfsigned}
    depends_on:
      - authelia
      - orthanc
      - ohif
      - auth-service
    networks:
      - orthanc-network

# =============================================================================
# PERSISTENT STORAGE
# =============================================================================

volumes:
  nginx-ssl:
    name: orthanc_nginx_ssl
  # postgres_data:  # Uncomment if using local PostgreSQL
  #   name: orthanc_postgres_data

# =============================================================================
# NETWORK CONFIGURATION
# =============================================================================

networks:
  orthanc-network:
    name: orthanc-network
    driver: bridge
  database:  # Remove this section if using local PostgreSQL
    external: true
    name: database