# ORTHANC-AUTHELIA STANDALONE - Complete medical imaging solution
# Postgres embarque par defaut = clone + bootstrap.sh + docker compose up
# Includes PostgreSQL, Redis, Orthanc, OHIF, Authelia, and Nginx
#
# =============================================================================
# QUICK START (recommended)
# =============================================================================
#
#   git clone https://github.com/yokoinc/orthanc-authelia.git
#   cd orthanc-authelia
#   ./bootstrap.sh              # genere .env + copie templates
#   docker compose up -d        # demarre les 6 services
#
# =============================================================================
# EXTERNAL DATABASE (advanced)
# =============================================================================
#
# Si tu as deja un postgres separe (autre stack docker, base managee, etc.),
# cree un docker-compose.override.yml a la racine :
#
#   services:
#     postgres:
#       profiles: ["disabled"]     # ne demarre jamais
#     orthanc:
#       networks:
#         - orthanc-network
#         - database                # ton reseau externe existant
#       environment:
#         - ORTHANC__POSTGRESQL__HOST=database
#   networks:
#     database:
#       external: true
#
# =============================================================================

services:
  # =============================================================================
  # DATABASE SERVICES
  # =============================================================================

  redis:
    image: redis:8.0-alpine
    container_name: orthanc-redis
    restart: unless-stopped
    healthcheck:
      test: ["CMD", "redis-cli", "ping"]
      interval: 10s
      timeout: 5s
      retries: 5
      start_period: 30s
    networks:
      - orthanc-network

  # ---------------------------------------------------------------------------
  # PostgreSQL embarque : marche out-of-the-box pour un clone frais.
  # Pour utiliser une DB externe, cf. la section "EXTERNAL DATABASE" en haut.
  # ---------------------------------------------------------------------------
  postgres:
    image: postgres:16-alpine
    container_name: orthanc-postgres
    restart: unless-stopped
    environment:
      - POSTGRES_DB=${POSTGRES_DB:-orthanc}
      - POSTGRES_USER=${POSTGRES_USER:-orthanc}
      - POSTGRES_PASSWORD=${POSTGRES_PASSWORD}
    volumes:
      - postgres_data:/var/lib/postgresql/data
    healthcheck:
      test: ["CMD-SHELL", "pg_isready -U ${POSTGRES_USER:-orthanc}"]
      interval: 10s
      timeout: 5s
      retries: 5
      start_period: 30s
    networks:
      - orthanc-network

  # =============================================================================
  # AUTHENTICATION SERVICES
  # =============================================================================
  
  auth-service:
    image: registry.yokoinc.ovh/orthanc-auth-service:1.0.16
    container_name: orthanc-auth-service
    restart: unless-stopped
    environment:
      # Essential Configuration (from .env)
      - LANGUAGE=${LANGUAGE}
      - AUTH_USERNAME=${AUTH_USERNAME}
      - AUTH_PASSWORD=${AUTH_PASSWORD}
      - REDIS_HOST=redis
      # Version semantique affichee en pied de page du token manager.
      # A synchroniser avec le tag de l'image ci-dessus (1.0.16) a chaque bump.
      - IMAGE_VERSION=1.0.16
      # Optional overrides (uncomment in .env if needed)
      - LOG_LEVEL=${LOG_LEVEL:-INFO}
      - DEFAULT_TOKEN_MAX_USES=${DEFAULT_TOKEN_MAX_USES:-50}
      - DEFAULT_TOKEN_VALIDITY_SECONDS=${DEFAULT_TOKEN_VALIDITY_SECONDS:-604800}
      - CACHE_VALIDITY_USER_SESSION=${CACHE_VALIDITY_USER_SESSION:-300}
      - CACHE_VALIDITY_SHARE_TOKEN=${CACHE_VALIDITY_SHARE_TOKEN:-60}
      - AUDIT_RETENTION_DAYS=${AUDIT_RETENTION_DAYS:-90}
      - JS_REFRESH_INTERVAL=${JS_REFRESH_INTERVAL:-30000}
      - JS_DEBUG_MODE=${JS_DEBUG_MODE:-false}
    depends_on:
      redis:
        condition: service_healthy
    networks:
      - orthanc-network

  authelia:
    image: authelia/authelia:4.39.5
    container_name: orthanc-authelia
    restart: unless-stopped
    depends_on:
      redis:
        condition: service_healthy
    volumes:
      - ./services/authelia/config:/config
    networks:
      - orthanc-network
    environment:
      - TZ=${TZ}
      - AUTHELIA_SESSION_SECRET=${AUTHELIA_SESSION_SECRET}
      - AUTHELIA_STORAGE_ENCRYPTION_KEY=${AUTHELIA_STORAGE_ENCRYPTION_KEY}
      - AUTHELIA_IDENTITY_VALIDATION_RESET_PASSWORD_JWT_SECRET=${AUTHELIA_JWT_SECRET}
      - AUTHELIA_LOG_LEVEL=${AUTHELIA_LOG_LEVEL:-info}
      - REDIS_HOST=redis
      - REDIS_PORT=6379
      - REDIS_DB=0

  # =============================================================================
  # PACS CORE SERVICES
  # =============================================================================
  
  orthanc:
    # Official Orthanc Team image (replaces jodogne/orthanc-plugins). Pin a specific
    # tag to know exactly which plugin versions ship; see release notes at
    # https://github.com/orthanc-server/orthanc-builder/blob/master/release-notes-docker-images.md
    image: orthancteam/orthanc:26.4.2
    container_name: orthanc-server
    restart: unless-stopped
    depends_on:
      auth-service:
        condition: service_started
      postgres:
        condition: service_healthy
    volumes:
      - ./services/orthanc/config/orthanc.json:/etc/orthanc/orthanc.json:ro
    networks:
      - orthanc-network
    environment:
      # Env vars ORTHANC__* overrident les valeurs du orthanc.json. Ca evite
      # d'avoir a hardcoder credentials + host dans le JSON, et permet de
      # basculer d'une DB embarquee a externe juste en changeant .env / override.
      - ORTHANC__POSTGRESQL__HOST=postgres
      - ORTHANC__POSTGRESQL__PORT=5432
      - ORTHANC__POSTGRESQL__DATABASE=${POSTGRES_DB:-orthanc}
      - ORTHANC__POSTGRESQL__USERNAME=${POSTGRES_USER:-orthanc}
      - ORTHANC__POSTGRESQL__PASSWORD=${POSTGRES_PASSWORD}
      # Kept for scripts backward compat (some helpers still read POSTGRES_*)
      - POSTGRES_HOST=postgres
      - POSTGRES_PORT=5432
      - POSTGRES_DB=${POSTGRES_DB:-orthanc}
      - POSTGRES_USER=${POSTGRES_USER:-orthanc}
      - POSTGRES_PASSWORD=${POSTGRES_PASSWORD}
      # --- Plugin enablement (orthancteam) -----------------------------------
      # orthancteam/orthanc auto-discovers bundled plugins; an env var (or a
      # config section) is required to enable each. Plugins whose orthanc.json
      # section is present (PostgreSQL, DicomWeb, Authorization, Housekeeper,
      # OrthancExplorer2) auto-enable, but we set the env vars explicitly for
      # robustness and to enable plugins without a dedicated config section
      # (Stone, VolView).
      - AUTHORIZATION_PLUGIN_ENABLED=true
      - POSTGRESQL_PLUGIN_ENABLED=true
      - DICOM_WEB_PLUGIN_ENABLED=true
      - STONE_WEB_VIEWER_PLUGIN_ENABLED=true
      - HOUSEKEEPER_PLUGIN_ENABLED=true
      - VOLVIEW_PLUGIN_ENABLED=true
      - ORTHANC_EXPLORER_2_ENABLED=true
      - GDCM_PLUGIN_ENABLED=true

  # =============================================================================
  # MEDICAL IMAGING VIEWERS
  # =============================================================================
  
  ohif:
    image: registry.yokoinc.ovh/orthanc-ohif:3.11.0
    container_name: orthanc-ohif
    restart: unless-stopped
    volumes:
      - ./services/ohif/config/app-config.js:/usr/share/nginx/html/ohif/app-config.js:ro
    depends_on:
      - orthanc
    networks:
      - orthanc-network

  # =============================================================================
  # REVERSE PROXY & LOAD BALANCER
  # =============================================================================
  
  nginx:
    # Image >= 1.1.0 no longer bakes the nginx config in: the templates are
    # bind-mounted from the host (see volumes below). Tags before 1.1.0 will
    # NOT start with these mounts because they expect the templates baked in.
    image: registry.yokoinc.ovh/orthanc-nginx:1.1.0
    container_name: orthanc-nginx
    restart: unless-stopped
    ports:
      - "30080:80"
      - "30443:443"
    volumes:
      - nginx-ssl:/etc/nginx/ssl
      # Bind-mount the nginx config from the host (git = source of truth).
      # The entrypoint runs envsubst on these and writes the resulting nginx.conf
      # and conf.d/*.conf to their normal /etc/nginx/ locations. Config tweaks
      # therefore deploy via:  edit files  ->  docker compose restart nginx
      # (no rebuild, no image push, no tag bump).
      - ./services/nginx/nginx.ssl.conf:/etc/nginx/templates/nginx.conf.template:ro
      - ./services/nginx/conf.d:/etc/nginx/conf.d.templates:ro
    environment:
      - DOMAIN=${DOMAIN}
      - SSL_MODE=${SSL_MODE:-selfsigned}
      # Optional: enables POST /api-upload/instances for scripted DICOM uploads
      # (bypasses Authelia SSO, uses HTTP Basic auth instead).
      - UPLOAD_USER=${UPLOAD_USER:-}
      - UPLOAD_PASSWORD=${UPLOAD_PASSWORD:-}
    depends_on:
      - authelia
      - orthanc
      - ohif
      - auth-service
    networks:
      - orthanc-network

# =============================================================================
# PERSISTENT STORAGE
# =============================================================================

volumes:
  nginx-ssl:
    name: orthanc_nginx_ssl
  postgres_data:
    name: orthanc_postgres_data

# =============================================================================
# NETWORK CONFIGURATION
# =============================================================================

networks:
  orthanc-network:
    name: orthanc-network
    driver: bridge