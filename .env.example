# =============================================================================
# ORTHANC-AUTHELIA ENVIRONMENT CONFIGURATION EXAMPLE
# =============================================================================
# Copy this file to .env and customize for your deployment.
# 
# SECURITY WARNING: Never commit the .env file to version control!
# =============================================================================

# =============================================================================
# DOMAIN CONFIGURATION
# =============================================================================
DOMAIN=pacs.example.com                          # Your PACS domain (used in nginx config)

# =============================================================================
# AUTHENTICATION CONFIGURATION
# =============================================================================
# Auth-service API credentials for Orthanc Authorization plugin
AUTH_USERNAME=share-user                         # API username
AUTH_PASSWORD=change_this_password_in_production # CHANGE THIS!

# Interface language (en/fr)
LANGUAGE=en                                      

# =============================================================================
# AUTHELIA SECURITY SECRETS
# =============================================================================
# Generate secure values with: openssl rand -base64 48
# Each secret must be at least 64 characters long

AUTHELIA_SESSION_SECRET=change_this_to_a_very_long_random_string_minimum_64_characters
AUTHELIA_STORAGE_ENCRYPTION_KEY=change_this_to_another_very_long_random_string_minimum_64_characters  
AUTHELIA_JWT_SECRET=change_this_to_yet_another_very_long_random_string_minimum_64_characters

# =============================================================================
# SYSTEM CONFIGURATION
# =============================================================================
# Timezone
TZ=Europe/Paris

# =============================================================================
# NOTES
# =============================================================================
# Database and Redis settings are configured for external services in docker-compose.yml
# User accounts are managed through Authelia's users_database.yml file
# Most other settings have sensible defaults and don't require environment variables