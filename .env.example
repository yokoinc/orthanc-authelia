# =============================================================================
# ORTHANC-AUTHELIA ENVIRONMENT CONFIGURATION EXAMPLE
# =============================================================================
# Copy this file to .env and customize for your deployment.
# All values will be processed by setup script with envsubst.
# 
# SECURITY WARNING: Never commit the .env file to version control!
# =============================================================================

# =============================================================================
# DOMAIN & NETWORK CONFIGURATION
# =============================================================================
AUTHELIA_DOMAIN=pacs.example.com                 # Your PACS domain
NGINX_EXTERNAL_PORT=80                           # External HTTP port

# =============================================================================
# DATABASE CONFIGURATION
# =============================================================================
# PostgreSQL database settings
POSTGRES_HOST=database                           # External: "database" | Internal: "postgres"
POSTGRES_DB=orthanc                              # Database name
POSTGRES_USER=orthanc                            # Database user
POSTGRES_PASSWORD=change_this_password_in_production  # CHANGE THIS!

# =============================================================================
# REDIS CONFIGURATION
# =============================================================================
REDIS_HOST=redis                                 # Redis hostname
REDIS_PORT=6379                                  # Redis port
REDIS_DB=0                                       # Redis database number

# =============================================================================
# AUTHENTICATION CONFIGURATION
# =============================================================================
# Auth-service API credentials
AUTH_USERNAME=share-user                         # API username
AUTH_PASSWORD=change_this_password_in_production # CHANGE THIS!

# Language configuration
LANGUAGE=en                                      # Interface language (en/fr)

# =============================================================================
# AUTHELIA SECURITY SECRETS
# =============================================================================
# Generate secure values with: openssl rand -base64 48
# Each secret must be at least 64 characters long
AUTHELIA_SESSION_SECRET=change_this_to_a_very_long_random_string_minimum_64_characters
AUTHELIA_STORAGE_ENCRYPTION_KEY=change_this_to_another_very_long_random_string_minimum_64_characters  
AUTHELIA_JWT_SECRET=change_this_to_yet_another_very_long_random_string_minimum_64_characters

# Authelia logging level
AUTHELIA_LOG_LEVEL=info                          # trace, debug, info, warn, error

# =============================================================================
# USER ACCOUNTS
# =============================================================================
# Default users (passwords will be hashed automatically)
# Format: USERNAME=email@domain.com PASSWORD=password ROLE=role_name

# Administrator (full access)
AUTHELIA_ADMIN_USERNAME=admin@example.com
AUTHELIA_ADMIN_PASSWORD=admin123                 # CHANGE THIS!
AUTHELIA_ADMIN_ROLE=admin

# Doctor (view, upload, share, modify)
AUTHELIA_DOCTOR_USERNAME=doctor@example.com
AUTHELIA_DOCTOR_PASSWORD=doctor123               # CHANGE THIS!
AUTHELIA_DOCTOR_ROLE=doctor

# External viewer (read-only access)
AUTHELIA_EXTERNAL_USERNAME=external@example.com
AUTHELIA_EXTERNAL_PASSWORD=external123           # CHANGE THIS!
AUTHELIA_EXTERNAL_ROLE=external-viewer

# =============================================================================
# OPTIONAL OVERRIDES
# =============================================================================
# These have sensible defaults, uncomment only if you need to change them

# Timezone
TZ=Europe/Paris

# OHIF Viewer
OHIF_PUBLIC_URL=/ohif/
# OHIF_HTTPS=true

# Logging
# LOG_LEVEL=INFO

# Token settings (auth-service defaults are usually fine)
# DEFAULT_TOKEN_MAX_USES=50
# DEFAULT_TOKEN_VALIDITY_SECONDS=604800            # 7 days
# AUDIT_RETENTION_DAYS=90

# Performance tuning
# CACHE_VALIDITY_USER_SESSION=300                  # 5 minutes
# CACHE_VALIDITY_SHARE_TOKEN=60                    # 1 minute

# Frontend settings
# JS_REFRESH_INTERVAL=30000
# JS_DEBUG_MODE=false