# =============================================================================
# ORTHANC-AUTHELIA ENVIRONMENT CONFIGURATION
# =============================================================================
# Copy this file to .env and fill in your actual values
# cp .env.example .env

# =============================================================================
# DOMAIN CONFIGURATION
# =============================================================================
DOMAIN=pacs.yourdomain.com

# =============================================================================
# AUTHENTICATION CONFIGURATION
# =============================================================================
# Auth-service API credentials for Orthanc Authorization plugin
# Must match the credentials in services/orthanc/config/orthanc.json
AUTH_USERNAME=share-user
AUTH_PASSWORD=your-secure-password-here

# Interface language (en/fr)
LANGUAGE=en

# =============================================================================
# AUTHELIA SECURITY SECRETS
# =============================================================================
# Generate secure random values using:
# openssl rand -base64 64 | tr -d '\n'
AUTHELIA_SESSION_SECRET=generate-a-random-64-char-string-here
AUTHELIA_STORAGE_ENCRYPTION_KEY=generate-another-random-64-char-string-here
AUTHELIA_JWT_SECRET=generate-yet-another-random-64-char-string-here

# =============================================================================
# SSL CONFIGURATION
# =============================================================================
# SSL mode: selfsigned (auto-generated) or none
SSL_MODE=selfsigned
SSL_ENABLED=true

# =============================================================================
# SYSTEM CONFIGURATION
# =============================================================================
# Timezone (see: https://en.wikipedia.org/wiki/List_of_tz_database_time_zones)
TZ=UTC

# =============================================================================
# OPTIONAL: ADVANCED CONFIGURATION
# =============================================================================
# Uncomment and modify these values if you need to customize behavior
# See README.md for details

# Logging
#LOG_LEVEL=INFO

# Token defaults
#DEFAULT_TOKEN_MAX_USES=50
#DEFAULT_TOKEN_VALIDITY_SECONDS=604800

# Cache settings
#CACHE_VALIDITY_USER_SESSION=300
#CACHE_VALIDITY_SHARE_TOKEN=60

# Audit
#AUDIT_RETENTION_DAYS=90

# JavaScript settings
#JS_REFRESH_INTERVAL=30000
#JS_DEBUG_MODE=false
