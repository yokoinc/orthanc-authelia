{
  // =============================================================================
  // ORTHANC PACS SERVER CONFIGURATION - EXAMPLE
  // =============================================================================
  // Copy to orthanc.json and update credentials
  
  "Name": "Orthanc",
  "HttpPort": 8042,
  "HttpServerEnabled": true,
  "DicomPort": 4242,
  "DicomServerEnabled": true,
  "DicomAet": "ORTHANC",
  "DicomCheckCalledAet": false,
  "DicomCheckModalityHost": false,
  "RemoteAccessAllowed": true,
  "AuthenticationEnabled": false,

  "DicomTlsEnabled": false,
  "HttpTimeout": 60,
  "HttpRequestTimeout": 30,

  "MaximumStorageSize": 0,
  "MaximumPatientCount": 0,
  "StorageCompression": false,

  // =============================================================================
  // POSTGRESQL - UPDATE THESE CREDENTIALS
  // =============================================================================
  "PostgreSQL": {
    "EnableIndex": true,
    "EnableStorage": true,
    "Host": "database",
    "Port": 5432,
    "Database": "orthanc",
    "Username": "your-postgres-username",
    "Password": "your-postgres-password"
  },

  // No explicit "Plugins" array here: with orthancteam/orthanc, bundled plugins
  // are auto-discovered from the image's own plugin directory and enabled
  // either by their env var (AUTHORIZATION_PLUGIN_ENABLED, ...) or by the
  // presence of their config section below. The hardcoded jodogne paths like
  // /usr/local/share/orthanc/plugins/lib*.so do NOT exist in orthancteam and
  // would prevent Orthanc from starting if listed here.

  "DicomWeb": {
    "Enable": true,
    "PublicRoot": "/dicom-web/"
  },

  "Housekeeper": {
    "Enable": true,
    "GlobalPropertyId": 1024,
    "Force": false,
    "ThrottleDelay": 100,
    "Triggers": {
      "StorageCompressionChange": true,
      "MainDicomTagsChange": true,
      "UnnecessaryDicomAsJsonFiles": true,
      "DicomWebCache": true
    }
  },

  "OrthancExplorer2": {
    "Enable": true,
    "IsDefaultOrthancUI": true,
    "Theme": "dark",
    "UiOptions": {
      "ShowOrthancName": true,
      "EnableViewerQuickButton": true,
      "ViewersOrdering": ["ohif", "stone-webviewer", "volview"],
      "OhifViewer3PublicRoot": "/ohif/",
      "StoneWebViewerPublicRoot": "/stone-webviewer/",
      "VolViewPublicRoot": "/volview/",
      "EnableOpenInOhifViewer3": true,
      "EnableOpenInStoneWebViewer": true,
      "EnableOpenInVolView": true,
      "EnableShares": true,
      "DefaultShareDuration": 15,
      "ShareDurations": [0, 7, 15, 30, 90, 365]
    },
    "EnableReportQuickButton": true,
    "Tokens": {
      "InstantLinksValidity": 200,
      "ShareType": "volview-viewer-publication"
    },
    "StudyListColumns": [
      "PatientID", "PatientName", "StudyDate", 
      "StudyDescription", "AccessionNumber", 
      "InstitutionName", "Modality"
    ],
    "CustomButtons": {
      "studies-list": [
        {
          "HttpMethod": "GET",
          "Id": "manage-tokens",
          "Tooltip": "Manage sharing tokens (Admin)",
          "Icon": "fas fa-key",
          "Url": "/auth/tokens/manage",
          "Target": "_blank"
        }
      ],
      "study": [],
      "series": [],
      "instance": []
    }
  },

  // =============================================================================
  // AUTHORIZATION - UPDATE USERNAME AND PASSWORD TO MATCH .env
  // =============================================================================
  "Authorization": {
    "CheckedLevel": "studies",
    "UncheckedFolders": ["/ui", "/favicon.ico"],
    "TokenHttpHeaders": ["X-Auth-User", "Remote-User", "auth-token"],
    "TokenGetParameters": ["token"],
    "WebServiceRootUrl": "http://auth-service:8000",
    "WebServiceTokenValidationUrl": "http://auth-service:8000/tokens/validate",
    "WebServiceUserProfileUrl": "http://auth-service:8000/user/get-profile",
    "WebServiceTokenCreationBaseUrl": "http://auth-service:8000/tokens/",
    "WebServiceUsername": "share-user",
    "WebServicePassword": "your-auth-password-here",
    "StandardConfigurations": [
      "orthanc-explorer-2",
      "ohif",
      "stone-webviewer",
      "volview"
    ]
  },

  "LogLevel": "default",
  "LogFile": "",
  "HttpVerbose": false,
  "DicomVerbose": false,
  "HttpsVerifyPeers": false,
  "HttpsCACertificates": ""
}
