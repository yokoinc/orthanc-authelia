# =============================================================================
# AUTHELIA USER DATABASE
# =============================================================================
# This file defines users, passwords (hashed), and their group memberships
#
# RECOMMENDED: Use the interactive management tool:
#   ./manage-authelia-users.sh
#
# Manual password hashing (if needed):
#   docker run --rm authelia/authelia:4.39.5 authelia crypto hash generate argon2 --password "your-password"
#
# Groups determine permissions (see configuration.yml for access control):
# - admin: Full PACS administration, token management, all functions
# - doctor: Medical imaging and patient data access
# - external: Limited read-only access

users:
  admin@example.com:
    displayname: "PACS Administrator"
    password: "$argon2id$v=19$m=65536,t=3,p=4$EXAMPLE_HASH_REPLACE_THIS"
    email: admin@example.com
    groups:
      - admin

  doctor@example.com:
    displayname: "Medical Doctor"
    password: "$argon2id$v=19$m=65536,t=3,p=4$EXAMPLE_HASH_REPLACE_THIS"
    email: doctor@example.com
    groups:
      - doctor

  external@example.com:
    displayname: "External User"
    password: "$argon2id$v=19$m=65536,t=3,p=4$EXAMPLE_HASH_REPLACE_THIS"
    email: external@example.com
    groups:
      - external
