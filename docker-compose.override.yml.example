# Additions au docker-compose.yml existant.
# A merger ou renommer en docker-compose.override.yml pour surcharge automatique.
#
# Paths adaptes a la structure reelle du repo :
#   services/orthanc/config/orthanc.json         (deja bind-mounte cote orthanc)
#   services/authelia/config/                    (bind-mount du dossier entier cote authelia)
#
# ============================================================================
# Prerequis one-shot sur le NAS avant premier up
# ============================================================================
#
# 1) Compte Orthanc dedie a auth-service (dans .env, non-editable via UI)
#   grep -q ORTHANC_ADMIN_USER .env || cat >> .env <<'EOF'
#   ORTHANC_ADMIN_USER=svc-auth
#   ORTHANC_ADMIN_PASS=$(openssl rand -hex 32)
#   EOF
#
# 2) Permissions bind-mounts (UID 1000)
#
# --- Linux natif / Docker Desktop / la plupart des NAS :
#   sudo chown -R 1000:1000 ./services/orthanc/config ./services/authelia/config ./data/admin-backups
#
# --- Synology DSM (specifique) :
#   DSM utilise des ACL Btrfs. `chown` classique peut etre partiellement
#   ecrase par l'ACL par defaut du partage. Deux options :
#
#   a) Le plus simple : creer les dossiers depuis File Station en tant que
#      l'utilisateur qui execute Docker (souvent 'docker' ou ton user perso),
#      puis via SSH :
#        sudo synoacltool -del ./services/orthanc/config/orthanc.json
#        sudo synoacltool -del ./services/authelia/config/users_database.yml
#        sudo chown 1000:1000 ./services/orthanc/config/orthanc.json
#        sudo chown 1000:1000 ./services/authelia/config/users_database.yml
#        sudo chmod 660 ./services/orthanc/config/orthanc.json
#        sudo chmod 660 ./services/authelia/config/users_database.yml
#
#   b) Plus propre : mettre les fichiers dans un volume Docker natif (pas
#      un partage DSM). Perd la commodite du File Station mais aucun probleme
#      d'ACL.
#
#   Verification :
#     docker exec orthanc-server id       # doit sortir uid=1000
#     docker exec orthanc-auth-service id # doit sortir uid=1000
#     docker exec orthanc-auth-service ls -l /host/orthanc.json
#     # -> -rw-rw---- 1 1000 1000

services:
  orthanc:
    user: "1000:1000"
    # (le bind-mount orthanc.json existe deja dans le compose principal,
    # rien a rajouter ici cote volumes)
    environment:
      # Compte Basic auth utilise par auth-service pour POST /tools/reset,
      # /modalities, /dicom-web/servers. Injecte via env vars pour rester
      # hors du orthanc.json edite par UI.
      - ORTHANC__REGISTERED_USERS={"${ORTHANC_ADMIN_USER}":"${ORTHANC_ADMIN_PASS}"}
      - ORTHANC__AUTHENTICATION_ENABLED=true

  authelia:
    user: "1000:1000"
    # (le bind-mount services/authelia/config existe deja, dossier entier)

  auth-service:
    user: "1000:1000"
    volumes:
      # Bind-mount croise : le meme fichier host que orthanc/authelia,
      # monte en RW cote auth-service pour edition depuis l'admin panel.
      - ./services/orthanc/config/orthanc.json:/host/orthanc.json:rw
      - ./services/authelia/config/users_database.yml:/host/authelia.yml:rw
      # Volume dedie aux backups rotatifs (10 derniers par fichier)
      - ./data/admin-backups:/host/backups:rw
    environment:
      # Credentials pour parler a Orthanc en Basic auth
      - ORTHANC_ADMIN_USER=${ORTHANC_ADMIN_USER}
      - ORTHANC_ADMIN_PASS=${ORTHANC_ADMIN_PASS}
      - ORTHANC_URL=http://orthanc:8042
      # Redis
      - REDIS_URL=${REDIS_URL:-redis://redis:6379/0}
      # Versions (deja injectees dans le chantier precedent)
      - IMAGE_VERSION=${IMAGE_VERSION}
      - ASSET_VERSION=${ASSET_VERSION}
